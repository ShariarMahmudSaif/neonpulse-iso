#!/bin/bash
# NeonPulse OS - First-Boot Setup Script
# Runs once after first login to configure the system

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Paths
CONFIG_DIR="${HOME}/.config/neonpulse"
LOCAL_SHARE="${HOME}/.local/share/neonpulse"
FIRST_BOOT_FLAG="${LOCAL_SHARE}/.first-boot-done"

# Functions
log_step() {
    echo -e "${CYAN}[*]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[✓]${NC} $1"
}

log_error() {
    echo -e "${RED}[✗]${NC} $1"
}

# Create directory structure
setup_directories() {
    log_step "Creating directory structure..."
    mkdir -p "$CONFIG_DIR"
    mkdir -p "$LOCAL_SHARE"
    mkdir -p "${HOME}/.config/hypr"
    mkdir -p "${HOME}/.config/waybar"
    mkdir -p "${HOME}/.local/bin"
    log_success "Directories created"
}

# Copy default configurations
setup_configs() {
    log_step "Setting up default configurations..."
    
    # Hyprland config
    if [[ ! -f "${HOME}/.config/hypr/hyprland.conf" ]]; then
        cp /etc/skel/.config/hypr/hyprland.conf "${HOME}/.config/hypr/" 2>/dev/null || true
    fi
    
    # Waybar config
    if [[ ! -f "${HOME}/.config/waybar/config" ]]; then
        cp /etc/skel/.config/waybar/config "${HOME}/.config/waybar/" 2>/dev/null || true
        cp /etc/skel/.config/waybar/style.css "${HOME}/.config/waybar/" 2>/dev/null || true
    fi
    
    log_success "Configurations copied"
}

# Install AUR packages
setup_aur_packages() {
    log_step "Installing AUR packages (Proton-GE, MangoHud, Heroic)..."
    
    if command -v yay &> /dev/null; then
        yay -S --noconfirm proton-ge-custom-bin mangohud-bin heroic-games-launcher-bin 2>/dev/null || {
            log_error "Failed to install some AUR packages (may require manual intervention)"
        }
        log_success "AUR packages installed"
    else
        log_error "yay not found - skipping AUR packages (install manually later)"
    fi
}

# Setup GPU drivers
setup_gpu_drivers() {
    log_step "Detecting and configuring GPU drivers..."
    
    # Detect GPU
    local gpu_vendor=$(lspci | grep -i "vga\|3d" | head -1)
    
    if echo "$gpu_vendor" | grep -qi "nvidia"; then
        log_step "NVIDIA GPU detected - ensuring proprietary drivers installed"
        if command -v nvidia-smi &> /dev/null; then
            log_success "NVIDIA drivers already installed"
            nvidia-smi
        else
            log_error "NVIDIA drivers not found - install nvidia package manually"
        fi
    elif echo "$gpu_vendor" | grep -qi "amd"; then
        log_success "AMD GPU detected - using open-source drivers"
        # Check if it's an APU (iGPU)
        if lspci | grep -qi "radeon\|amdgpu"; then
            log_step "AMD iGPU/APU detected (Ryzen 5000G/7000G or older)"
            log_success "amdgpu driver provides full support"
            if command -v radeontop &> /dev/null; then
                log_success "AMD tools installed"
                radeontop -c -b -t 1 2>/dev/null || true
            fi
        fi
    elif echo "$gpu_vendor" | grep -qi "intel"; then
        log_success "Intel GPU detected - configuring drivers"
        # Check if it's an iGPU
        if lspci | grep -qi "iris\|uhd\|hd graphics\|arc"; then
            log_step "Intel iGPU detected"
            log_success "i915 driver with Mesa support enabled"
        fi
    fi
}

# Enable systemd services
setup_services() {
    log_step "Enabling system services..."
    
    systemctl --user enable pipewire.service || true
    systemctl --user enable wireplumber.service || true
    
    # Enable thermal management
    sudo systemctl enable thermald.service 2>/dev/null || true
    sudo systemctl enable power-profiles-daemon.service 2>/dev/null || true
    
    log_success "Services enabled"
}

# Start daemons
start_daemons() {
    log_step "Starting NeonPulse daemons..."
    
    # Make sure scripts are executable
    chmod +x /usr/local/bin/neonpulse-resource-guard 2>/dev/null || true
    chmod +x /usr/local/bin/neonpulse-security-daemon 2>/dev/null || true
    
    # Start resource guard
    if command -v neonpulse-resource-guard &> /dev/null; then
        neonpulse-resource-guard daemon &
        log_success "Resource Guard daemon started"
    fi
    
    # Start security daemon
    if command -v neonpulse-security-daemon &> /dev/null; then
        neonpulse-security-daemon daemon &
        log_success "Security Daemon started"
    fi
}

# Create terminal theme
setup_terminal() {
    log_step "Configuring terminal..."
    
    # Create Kitty config
    mkdir -p "${HOME}/.config/kitty"
    cat > "${HOME}/.config/kitty/kitty.conf" << 'EOL'
# NeonPulse OS - Kitty Terminal Config
font_family JetBrains Mono
font_size 11
background #0a0a0a
foreground #00ffff
cursor #ff00ff
selection_background #ff00ff
selection_foreground #0a0a0a

# Neon colors
color0 #1a1a1a
color1 #ff1493
color2 #00ff64
color3 #ffff00
color4 #00bfff
color5 #ff00ff
color6 #00ffff
color7 #e0e0e0
color8 #505050
color9 #ff69b4
color10 #00ff7f
color11 #ffff54
color12 #87ceeb
color13 #ff1493
color14 #00ffff
color15 #ffffff

# Glassmorphic window
background_opacity 0.95
window_padding_width 10
window_margin_width 5

# Wayland
linux_display_server wayland
EOL
    log_success "Kitty configured"
    
    # Bash/Zsh configuration
    if [[ ! -f "${HOME}/.bashrc.local" ]]; then
        cat >> "${HOME}/.bashrc" << 'EOL'

# NeonPulse OS Customizations
alias ls='ls --color=auto'
alias ll='ls -lah'
alias grep='grep --color=auto'
alias neofetch='neofetch --ascii'

# Prompt color (neon cyan)
PS1='\[\033[36m\][\u@\h \W]\$\[\033[0m\] '

# Enable command line edit mode
set -o vi

# Welcome message
echo -e "\033[35m.───────────────────────────────────────.\033[0m"
echo -e "\033[36m│  Welcome to NeonPulse OS          │\033[0m"
echo -e "\033[35m│  Creator-First • Gaming Optimized │\033[0m"
echo -e "\033[35m'───────────────────────────────────────'\033[0m"
EOL
    fi
}

# Setup gaming optimization
setup_gaming() {
    log_step "Configuring gaming optimizations..."
    
    # Gamemode config
    mkdir -p "${HOME}/.config/gamemode"
    
    # Steam settings
    mkdir -p "${HOME}/.steam/steam"
    
    # Enable Proton experimental
    mkdir -p "${HOME}/.steam/steam/compatibilitytools.d"
    
    log_success "Gaming configurations ready"
}

# Setup multimedia directories
setup_multimedia() {
    log_step "Creating multimedia directories..."
    mkdir -p "${HOME}/Videos"
    mkdir -p "${HOME}/Music"
    mkdir -p "${HOME}/Pictures/Screenshots"
    mkdir -p "${HOME}/Projects/BlenderProjects"
    mkdir -p "${HOME}/Projects/VideoEditing"
    log_success "Multimedia directories created"
}

# Create wallpaper (placeholder SVG)
setup_wallpapers() {
    log_step "Setting up wallpapers..."
    
    mkdir -p "${HOME}/.local/share/backgrounds"
    
    # Create default neon wallpaper SVG
    cat > "${HOME}/.local/share/backgrounds/neonpulse-default.svg" << 'EOF'
<svg width="1920" height="1080" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Dark background -->
  <rect width="1920" height="1080" fill="#0a0a0a"/>
  
  <!-- Gradient background -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a0033;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#0a0a1a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#000033;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#bgGradient)"/>
  
  <!-- Neon grid lines -->
  <g stroke="#ff00ff" stroke-width="1" opacity="0.1">
    <line x1="0" y1="100" x2="1920" y2="100"/>
    <line x1="0" y1="200" x2="1920" y2="200"/>
    <line x1="0" y1="300" x2="1920" y2="300"/>
    <line x1="0" y1="400" x2="1920" y2="400"/>
    <line x1="0" y1="500" x2="1920" y2="500"/>
    <line x1="0" y1="600" x2="1920" y2="600"/>
    <line x1="0" y1="700" x2="1920" y2="700"/>
    <line x1="0" y1="800" x2="1920" y2="800"/>
    <line x1="0" y1="900" x2="1920" y2="900"/>
    <line x1="200" y1="0" x2="200" y2="1080"/>
    <line x1="400" y1="0" x2="400" y2="1080"/>
    <line x1="600" y1="0" x2="600" y2="1080"/>
    <line x1="800" y1="0" x2="800" y2="1080"/>
    <line x1="1000" y1="0" x2="1000" y2="1080"/>
    <line x1="1200" y1="0" x2="1200" y2="1080"/>
    <line x1="1400" y1="0" x2="1400" y2="1080"/>
    <line x1="1600" y1="0" x2="1600" y2="1080"/>
    <line x1="1800" y1="0" x2="1800" y2="1080"/>
  </g>
  
  <!-- Neon circles -->
  <circle cx="200" cy="150" r="80" fill="none" stroke="#00ffff" stroke-width="2" opacity="0.6" filter="url(#glow)"/>
  <circle cx="1720" cy="900" r="120" fill="none" stroke="#ff00ff" stroke-width="2" opacity="0.6" filter="url(#glow)"/>
  <circle cx="960" cy="540" r="60" fill="none" stroke="#ff1493" stroke-width="2" opacity="0.4" filter="url(#glow)"/>
  
  <!-- NeonPulse text -->
  <text x="960" y="540" font-family="monospace" font-size="72" fill="#00ffff" text-anchor="middle" filter="url(#glow)" opacity="0.9">
    NeonPulse OS
  </text>
</svg>
EOF
    
    log_success "Wallpapers created"
}

# Create welcome dialog
setup_welcome() {
    log_step "Creating welcome dialog..."
    
    cat > "${LOCAL_SHARE}/welcome.txt" << 'EOF'
╔══════════════════════════════════════════════════════════════╗
║                                                              ║
║         🌀  WELCOME TO NEONPULSE OS  🌀                     ║
║                                                              ║
║      Creator-First • Gaming-Optimized • Cyberpunk Aesthetic ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝

🔧 FIRST-TIME SETUP COMPLETE

Your system has been configured with:
  ✓ Hyprland (Wayland with glass effects)
  ✓ Waybar (neon-themed top panel)
  ✓ Resource Guard (smart app limiting)
  ✓ Security Daemon (ClamAV + AppArmor + Firejail)
  ✓ Gaming optimizations (Steam, Proton-GE, Lutris)
  ✓ Professional tools (Blender, Kdenlive, GIMP, etc.)

🎮 GAMING:
  • Launch: steam, lutris, heroic
  • Enable MangoHud overlay (Ctrl+Shift+M in games)
  • Set Gamemode: gamemoded

📊 RESOURCE MONITORING:
  • Resource Guard: neonpulse-resource-guard status
  • System Monitor: htop or btop
  • Security Check: neonpulse-security-daemon status

🎨 CUSTOMIZATION:
  • Edit Hyprland: ~/.config/hypr/hyprland.conf
  • Edit Waybar: ~/.config/waybar/config
  • Wallpapers: ~/.local/share/backgrounds/

⌨️  KEYBOARD SHORTCUTS:
  • Super+Return  → Terminal (Kitty)
  • Super+B       → Browser (Brave)
  • Super+E       → File Manager
  • Super+Space   → App Menu
  • Super+Q       → Close Window
  • Super+F       → Fullscreen
  • Super+V       → Toggle Float

📚 DOCUMENTATION:
  • GitHub: https://github.com/yourusername/neonpulse-os
  • Read README for full feature list
  • Visit r/unixporn and r/linux_gaming

🌐 COMMUNITY:
  • Star the repo on GitHub
  • Join Discord: [your-discord-link]
  • Report issues and suggest features

Happy creating! 🔥
EOF
    
    log_success "Welcome dialog created"
}

# Show final summary
show_summary() {
    echo ""
    echo -e "${MAGENTA}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║${NC}                                                              ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}  ${CYAN}✓ NeonPulse OS First-Boot Setup Complete!${NC}              ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}                                                              ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${GREEN}Next steps:${NC}"
    echo "  1. Restart Hyprland (Super+Alt+R or reboot)"
    echo "  2. Customize via ~/.config/hypr/hyprland.conf"
    echo "  3. Check resource usage with: neonpulse-resource-guard status"
    echo "  4. Start gaming with Steam/Lutris/Heroic"
    echo ""
    echo -e "${CYAN}Have fun! 🔥${NC}"
    echo ""
}

# Main execution
main() {
    if [[ -f "$FIRST_BOOT_FLAG" ]]; then
        echo -e "${YELLOW}[!] First-boot already completed. Skipping...${NC}"
        exit 0
    fi
    
    echo -e "${MAGENTA}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║${NC}     ${CYAN}NeonPulse OS - First-Boot Setup${NC}                    ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    setup_directories
    setup_configs
    setup_gpu_drivers
    setup_services
    setup_terminal
    setup_gaming
    setup_multimedia
    setup_wallpapers
    setup_welcome
    setup_aur_packages
    start_daemons
    
    # Mark first boot as done
    touch "$FIRST_BOOT_FLAG"
    
    show_summary
}

main "$@"
